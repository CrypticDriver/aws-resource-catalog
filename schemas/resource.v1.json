{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://aws-resource-catalog.dev/schemas/resource.v1.json",
  "title": "AWS Resource Catalog Entry",
  "description": "One file per billable AWS resource type.",
  "type": "object",
  "required": ["service", "resource_type", "billing", "lifecycle"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "v1"
    },
    "status": {
      "type": "string",
      "enum": ["stub", "in_review", "verified"],
      "description": "Curation status. 'stub' = auto-generated scaffold, fields TODO. 'in_review' = partially curated. 'verified' = doc-cited and reviewed."
    },
    "service": {
      "type": "string",
      "description": "Short service name, e.g. emr / ec2 / sagemaker. Lowercase."
    },
    "service_code_pricing": {
      "type": "string",
      "description": "AWS Pricing API service code, e.g. ElasticMapReduce."
    },
    "service_code_arn_namespace": {
      "type": "string",
      "description": "ARN service namespace, e.g. emrwal / ec2 / sagemaker."
    },
    "resource_type": {
      "type": "object",
      "required": ["name", "human_name"],
      "properties": {
        "name": {"type": "string", "description": "Short id, e.g. emrwal_workspace."},
        "human_name": {"type": "string", "description": "Display name."},
        "human_name_zh": {"type": "string"},
        "cfn": {"type": ["string", "null"], "description": "AWS::Service::Resource form, or null if unsupported."},
        "config": {"type": ["string", "null"], "description": "AWS Config resourceType, or null."},
        "resource_explorer": {"type": ["string", "null"]},
        "cli_list": {"type": ["string", "null"], "description": "Shell command to list resources."},
        "boto3": {
          "type": ["object", "null"],
          "properties": {
            "client": {"type": "string"},
            "list_method": {"type": "string"}
          }
        },
        "arn_pattern": {"type": "string"}
      }
    },
    "billing": {
      "type": "object",
      "required": ["billable", "model"],
      "properties": {
        "billable": {"type": "boolean"},
        "model": {
          "type": "string",
          "enum": ["per-hour", "per-second", "per-gb-month", "per-request", "tiered-storage", "flat-monthly", "free", "complex"]
        },
        "summary": {"type": "string", "description": "One-line plain-language description of what is charged."},
        "cur_product_codes": {
          "type": "array",
          "items": {"type": "string"}
        },
        "cur_usage_type_patterns": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Glob/regex of CUR usage_type. Helps map a billing line to this resource type."
        },
        "free_tier": {"type": "boolean"},
        "doc_pricing_page": {"type": "string", "format": "uri"}
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "parent_resource": {
          "type": ["string", "null"],
          "description": "Logical parent resource type. null means top-level."
        },
        "parent_link": {
          "type": ["string", "null"],
          "description": "How this resource is logically tied to its parent (e.g. shared S3 root, ARN reference, tag, name match)."
        },
        "auto_delete_on_parent_delete": {
          "type": "boolean",
          "description": "True if AWS automatically deletes this when its parent goes away."
        },
        "retention_after_parent_delete": {
          "type": ["string", "null"],
          "description": "ISO-ish duration if AWS holds it for a while (e.g. P30D)."
        },
        "retention_caveats": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Edge cases that break the auto-delete promise."
        },
        "doc_lifecycle_anchor": {"type": "string", "format": "uri"}
      }
    },
    "orphan_detection": {
      "type": "object",
      "properties": {
        "orphan_prone": {"type": "boolean"},
        "severity": {"type": "string", "enum": ["high", "medium", "low"]},
        "rule_human": {"type": "string", "description": "Plain-language judgment rule."},
        "rule_pseudocode": {"type": "string"},
        "cleanup_command": {"type": "string"},
        "cleanup_safety": {"type": "string", "enum": ["safe", "needs_review", "destructive"]},
        "iam_required": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Free-form labels: billable / orphan_prone / storage / network / serverless ..."
    },
    "scan": {
      "type": "object",
      "description": "Machine-readable scan configuration for the orphan-scanner engine.",
      "properties": {
        "list": {
          "type": "object",
          "required": ["boto3_client", "method"],
          "properties": {
            "boto3_client": {"type": "string", "description": "boto3 client name, e.g. 'ec2'."},
            "method": {"type": "string", "description": "boto3 method name, e.g. 'describe_addresses'."},
            "args": {"type": "object", "description": "Static kwargs for the call."},
            "response_path": {"type": "string", "description": "Key in the response that holds the resource list."},
            "id_field": {"type": "string", "description": "Field name on each item that uniquely identifies the resource."},
            "name_field": {"type": "string", "description": "Field name to use as a human-readable label."},
            "paginated": {"type": "boolean", "default": false}
          }
        },
        "orphan_check": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["field_check", "parent_terminated", "no_traffic", "cross_reference", "custom"]
            },
            "field": {"type": "string", "description": "field_check: which field to inspect."},
            "condition": {
              "type": "string",
              "enum": ["empty", "not_empty", "equals", "not_equals", "older_than"]
            },
            "value": {"description": "Comparison value when condition is equals/not_equals/older_than."},
            "metric_namespace": {"type": "string", "description": "no_traffic: CloudWatch namespace."},
            "metric_name": {"type": "string"},
            "lookback_days": {"type": "integer", "minimum": 1},
            "threshold": {"type": "number"},
            "min_age_days": {"type": "integer", "description": "Only consider resources older than this."},
            "reference_resource": {"type": "string", "description": "cross_reference: the catalog id to diff against."},
            "custom_module": {"type": "string", "description": "custom: dotted python path to a callable."}
          }
        },
        "cost_estimate": {
          "type": "object",
          "properties": {
            "monthly_usd": {"type": "number", "description": "Hard-coded monthly USD per orphan."},
            "monthly_usd_per_gb": {"type": "number", "description": "Per-GB monthly when storage based."},
            "size_field": {"type": "string", "description": "Field on the resource that holds size in GB."},
            "cur_usage_type": {"type": "string"}
          }
        },
        "cleanup": {
          "type": "object",
          "properties": {
            "boto3_method": {"type": "string"},
            "args_template": {"type": "object", "description": "kwargs template; values can reference {fields} from the resource."},
            "cli_command": {"type": "string", "description": "Shell-friendly form for runbooks."},
            "safety": {"type": "string", "enum": ["safe", "needs_review", "destructive"]}
          }
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "last_verified": {"type": "string", "format": "date"},
        "source_doc_version": {"type": "string"},
        "contributor": {"type": "string"}
      }
    }
  }
}
